---
const agents = [
  { id:'alpha', name:'ALPHA PRIME', role:'Market Analysis', color:'violet', x:16, y:12, task:'Scans market trends, identifies patterns, predicts moves', state:'ANALYZING' },
  { id:'quantum', name:'QUANTUM NODE', role:'Signal Generation', color:'purple', x:15, y:56, task:'Generates high-probability signals from models', state:'SIGNALING' },
  { id:'sigma', name:'SIGMA SCOUT', role:'Sentiment Tracking', color:'emerald', x:35, y:67, task:'Monitors news, social mood, crowd momentum', state:'SCANNING' },
  { id:'data', name:'DATA WEAVER', role:'Pattern Recognition', color:'cyan', x:52, y:71, task:'Turns raw streams into actionable intelligence', state:'WEAVING' },
  { id:'nexus', name:'NEXUS CORE', role:'Strategy Engine', color:'sky', x:73, y:14, task:'Tests and optimizes strategies across conditions', state:'THINKING' },
  { id:'omega', name:'OMEGA VAULT', role:'Risk Management', color:'amber', x:82, y:42, task:'Checks exposure, invalidation, sizing, and safety', state:'GUARDING' },
  { id:'echo', name:'ECHO MIND', role:'News & Intel', color:'fuchsia', x:72, y:66, task:'Aggregates global news and catalyst intelligence', state:'LISTENING' },
];
const feed = [
  ['ALPHA PRIME','Detected market regime shift','Volatility increased +18.2%','violet'],
  ['NEXUS CORE','Strategy optimization complete','Sharpe ratio improved +0.23','sky'],
  ['SIGMA SCOUT','Social sentiment bullish','AI confidence surge 87%','emerald'],
  ['ECHO MIND','Breaking catalyst packaged','Sent packet to Trading Floor','fuchsia'],
  ['DATA WEAVER','Pattern match identified','Confidence: 92.4%','cyan'],
  ['OMEGA VAULT','Risk threshold adjusted','Exposure reduced 12.7%','amber'],
  ['QUANTUM NODE','High probability signal','Win rate: 89.3%','purple'],
  ['CEO B COMMAND','Final research synthesis ready','Awaiting human review','orange'],
];
const checklist = [
  'Build separate Staging page: Command + Signals only',
  'Add Vision Map with clearer ecosystem paths',
  'Create Archive page for saved “my way out / be rich” research',
  'Add Founder page with 5 founder images and personal story areas',
  'Make every agent clickable: details, checklist, logs, and next action',
  'Connect browser bookmark import to Knowledge Core intake queue',
  'Add CEO B final review queue before any live execution',
];
---
<section class="habitat-shell" data-agent-habitat>
  <aside class="sidebar glass-panel">
    <div class="brand"><div class="mark">TT</div><div><b>AI HABITAT OS</b><span>by PICKAXE CAPITAL</span></div></div>
    {['Agent Habitat','Vision Map','Market Command','Desk Brief','Staging','Watchlist','Alert Blueprints','Agents','Signal Engine','Archive','Founder','Resources','Settings'].map((item, idx)=>(
      <a class:list={['nav-item', idx===0 && 'active']} href={item==='Agent Habitat'?'/agents':`/${item.toLowerCase().replaceAll(' ','-')}`}> <span class="nav-dot"></span>{item}</a>
    ))}
    <div class="quote">“Command does not redo. Command upgrades, separates, and ships.”<br><b>— CEO B</b></div>
  </aside>

  <main class="habitat-main">
    <header class="topbar">
      <div><h1>AGENT HABITAT</h1><p>Your AI Workforce. Always Working.</p></div>
      <div class="stats glass-panel">
        <div><span>Total Agents</span><b data-count="1842">1,842</b></div>
        <div><span>Active</span><b class="green">1,326</b></div>
        <div><span>Tasks Running</span><b>247</b></div>
        <div><span>Completed Today</span><b>12,847</b></div>
        <div><span>Success Rate</span><b class="green">98.7%</b></div>
        <div><span>Uptime</span><b class="green">99.98%</b></div>
      </div>
      <div class="globe-card glass-panel"><div class="globe" aria-label="Rotating global intelligence globe"></div><small>GLOBAL LIVE</small></div>
    </header>

    <section class="stage glass-panel">
      <div class="skyline"></div>
      <div class="ceo-command glass-panel"><b>CEO B COMMAND CENTER</b><span>Final Research • Strategy Oversight • Human Review Gate</span></div>
      <div class="trading-floor">
        <div class="floor-rings"></div>
        <h2>TRADING FLOOR</h2>
        <p>Central hub for research, execution, and agent collaboration</p>
        <div class="floor-agents">
          {Array.from({length:22}).map((_,i)=><i style={`--i:${i}; --delay:${(i%7)*-.45}s`}></i>)}
        </div>
      </div>

      <svg class="paths" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
        <defs>
          <filter id="glow"><feGaussianBlur stdDeviation="1.2" result="coloredBlur"/><feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
        </defs>
        <path class="path violet" d="M20 24 C28 34, 37 39, 50 50" />
        <path class="path purple" d="M21 67 C30 58, 38 54, 50 50" />
        <path class="path emerald" d="M38 72 C42 63, 46 57, 50 50" />
        <path class="path cyan" d="M54 73 C54 64, 52 57, 50 50" />
        <path class="path sky" d="M75 25 C68 34, 61 40, 50 50" />
        <path class="path amber" d="M82 50 C72 50, 62 50, 50 50" />
        <path class="path fuchsia" d="M75 72 C67 61, 59 55, 50 50" />
      </svg>

      {agents.map((agent, index)=>(
        <article class:list={['agent-pod', agent.color]} style={`--x:${agent.x}%;--y:${agent.y}%;--delay:${index*-.8}s`} data-agent={agent.id} tabindex="0">
          <div class="dome"></div>
          <div class="pod-label glass-panel"><b>{agent.name}</b><span>{agent.role}</span><small>{agent.state}</small></div>
          <p class="agent-detail">{agent.task}</p>
          <div class="pod-workers"><i></i><i></i><i></i></div>
        </article>
      ))}

      <div class="moving-agent route-a"><i></i></div>
      <div class="moving-agent route-b"><i></i></div>
      <div class="moving-agent route-c"><i></i></div>
      <div class="moving-agent route-d"><i></i></div>
      <div class="data-cube cube-a"></div>
      <div class="data-cube cube-b"></div>
      <div class="data-cube cube-c"></div>
    </section>

    <section class="bottom-grid">
      <div class="glass-panel card"><h3>MISSION PROGRESS</h3><div class="gauge"><b>87%</b></div><p>28 / 32 daily objectives completed</p></div>
      <div class="glass-panel card"><h3>AGENT INTERACTIONS</h3><div class="network-mini"><i></i><i></i><i></i><i></i><i></i></div><p>Agents cluster when tasks overlap, then split back to home pods.</p></div>
      <div class="glass-panel card"><h3>SYSTEM PERFORMANCE</h3><ul><li>CPU <b>72%</b></li><li>Memory <b>68%</b></li><li>Network <b>81%</b></li><li>Reliance <b>94%</b></li></ul></div>
      <div class="glass-panel card checklist"><h3>IMMEDIATE BUILD CHECKLIST</h3>{checklist.slice(0,5).map(item=><label><input type="checkbox"/> {item}</label>)}</div>
    </section>
  </main>

  <aside class="right-feed glass-panel">
    <div class="feed-head"><b>LIVE OPERATIONS FEED</b><span>● LIVE</span></div>
    {feed.map((f,i)=>(
      <div class:list={['feed-item', f[3]]} style={`--delay:${i*.12}s`}><i></i><div><time>{`14:${String(32-i).padStart(2,'0')}`}</time><b>{f[0]}</b><p>{f[1]}</p><small>{f[2]}</small></div></div>
    ))}
    <button class="full-log">VIEW FULL LOGS →</button>
  </aside>

  <dialog class="agent-modal glass-panel" data-agent-modal>
    <button class="close-modal" data-close-modal>×</button>
    <h2 data-modal-title>Agent Detail</h2>
    <p data-modal-body>Agent operating details.</p>
    <div class="modal-actions"><button>Open Checklist</button><button>Send to CEO B</button><button>Archive Finding</button></div>
  </dialog>
</section>

<style>
:root{--bg:#05070d;--panel:rgba(7,13,25,.78);--line:rgba(111,154,255,.18);--text:#eef4ff;--muted:#93a2ba;--gold:#f7b84b;--green:#35f28b;--violet:#a855f7;--cyan:#20d3ff;--amber:#f59e0b;--emerald:#10d98b;--fuchsia:#e879f9;--sky:#38bdf8;}
*{box-sizing:border-box}.habitat-shell{min-height:100vh;background:radial-gradient(circle at 50% 15%,#172247 0%,#070a12 45%,#02030a 100%);color:var(--text);font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe UI,sans-serif;display:grid;grid-template-columns:260px minmax(0,1fr) 300px;gap:14px;padding:14px;overflow:hidden}.glass-panel{background:linear-gradient(180deg,rgba(13,22,39,.82),rgba(5,9,18,.86));border:1px solid rgba(122,151,218,.18);box-shadow:0 0 0 1px rgba(255,255,255,.03) inset,0 18px 60px rgba(0,0,0,.35);backdrop-filter:blur(12px);border-radius:16px}.brand{display:flex;gap:12px;align-items:center;padding:10px 8px 24px}.brand .mark{width:46px;height:46px;border-radius:14px;background:linear-gradient(135deg,#221406,#f7b84b 45%,#33200b);display:grid;place-items:center;font-weight:900;color:#08090e}.brand b{display:block;letter-spacing:.08em}.brand span{display:block;color:#c99d57;font-size:12px}.sidebar{padding:14px}.nav-item{height:43px;display:flex;align-items:center;gap:12px;padding:0 12px;margin:4px 0;border-radius:11px;color:#c6d0df;text-decoration:none;font-size:14px;letter-spacing:.03em}.nav-item:hover,.nav-item.active{background:linear-gradient(90deg,rgba(113,69,255,.38),rgba(28,118,255,.12));color:#fff;border:1px solid rgba(160,126,255,.32)}.nav-dot{width:18px;height:18px;border-radius:7px;border:1px solid currentColor;opacity:.75}.quote{margin-top:22px;padding:18px;border-radius:14px;background:rgba(255,255,255,.03);color:#b8c2d3;font-size:13px;line-height:1.5}.habitat-main{min-width:0;display:flex;flex-direction:column;gap:12px}.topbar{display:grid;grid-template-columns:260px 1fr 168px;gap:12px;align-items:stretch}.topbar h1{margin:0;font-size:32px;letter-spacing:.05em}.topbar p{margin:4px 0 0;color:#b6c0d4}.stats{display:grid;grid-template-columns:repeat(6,1fr);padding:12px 18px;gap:8px}.stats div{border-left:1px solid rgba(255,255,255,.1);padding-left:12px}.stats span{text-transform:uppercase;color:#91a0b7;font-size:10px;letter-spacing:.1em}.stats b{display:block;font-size:22px;color:#b276ff}.stats .green,.green{color:var(--green)}.globe-card{display:grid;place-items:center;padding:8px;color:#97b6ff}.globe{width:62px;height:62px;border-radius:50%;border:1px solid #3575ff;background:radial-gradient(circle at 35% 35%,#4bc3ff 0 8%,transparent 10%),repeating-linear-gradient(0deg,transparent 0 10px,rgba(72,122,255,.45) 11px),repeating-linear-gradient(90deg,transparent 0 10px,rgba(72,122,255,.35) 11px);box-shadow:0 0 30px #3b5bff;animation:spin 8s linear infinite}.stage{position:relative;height:640px;overflow:hidden;border-radius:22px}.skyline{position:absolute;inset:0;background:radial-gradient(circle at 50% 42%,rgba(255,180,60,.18),transparent 24%),linear-gradient(180deg,rgba(9,18,36,.25),rgba(0,0,0,.2)),repeating-linear-gradient(90deg,rgba(255,255,255,.05) 0 1px,transparent 1px 64px),repeating-linear-gradient(0deg,rgba(255,255,255,.04) 0 1px,transparent 1px 58px);opacity:.9}.ceo-command{position:absolute;left:50%;top:4%;transform:translateX(-50%);width:300px;text-align:center;padding:14px;z-index:5;border-color:rgba(247,184,75,.4)}.ceo-command b{display:block;color:#ffd589}.ceo-command span{font-size:12px;color:#aebbd0}.trading-floor{position:absolute;left:50%;top:49%;transform:translate(-50%,-50%);width:350px;height:230px;border-radius:50%;display:grid;place-items:center;text-align:center;z-index:4;background:radial-gradient(circle,rgba(255,191,75,.38),rgba(255,191,75,.10) 45%,transparent 70%);box-shadow:0 0 90px rgba(247,184,75,.45)}.floor-rings,.floor-rings:before,.floor-rings:after{content:"";position:absolute;inset:15%;border-radius:50%;border:1px solid rgba(255,210,117,.6);animation:pulse 2.4s ease-in-out infinite}.floor-rings:before{inset:-24%;animation-delay:.4s}.floor-rings:after{inset:32%;animation-delay:.8s}.trading-floor h2{margin:0;color:#ffcc72;letter-spacing:.08em;z-index:2}.trading-floor p{z-index:2;max-width:240px;color:#d7c5a1;font-size:13px}.floor-agents{position:absolute;inset:12%}.floor-agents i{position:absolute;width:11px;height:18px;border-radius:8px 8px 3px 3px;background:linear-gradient(#93c5fd,#111827);left:calc(50% + cos(var(--i))*1px);top:50%;transform:rotate(calc(var(--i)*16deg)) translateY(-74px);box-shadow:0 0 12px #60a5fa;animation:agentBob 1.8s ease-in-out infinite var(--delay)}.paths{position:absolute;inset:0;z-index:2;filter:url(#glow)}.path{fill:none;stroke-width:1.1;stroke-dasharray:5 5;animation:dash 5s linear infinite}.path.violet{stroke:var(--violet)}.path.purple{stroke:#c026d3}.path.emerald{stroke:var(--emerald)}.path.cyan{stroke:var(--cyan)}.path.sky{stroke:var(--sky)}.path.amber{stroke:var(--amber)}.path.fuchsia{stroke:var(--fuchsia)}.agent-pod{position:absolute;left:var(--x);top:var(--y);transform:translate(-50%,-50%);width:210px;height:150px;z-index:3}.dome{position:absolute;inset:0;border-radius:50% 50% 20% 20%;background:radial-gradient(circle at 50% 65%,rgba(255,255,255,.16),rgba(255,255,255,.04) 48%,transparent 70%);border:1px solid currentColor;box-shadow:0 0 40px currentColor;color:rgba(96,165,250,.55);animation:podBreathe 3.5s ease-in-out infinite var(--delay)}.agent-pod.violet{color:#a855f7}.agent-pod.purple{color:#c026d3}.agent-pod.emerald{color:#10d98b}.agent-pod.cyan{color:#20d3ff}.agent-pod.sky{color:#38bdf8}.agent-pod.amber{color:#f59e0b}.agent-pod.fuchsia{color:#e879f9}.pod-label{position:absolute;left:50%;top:26px;transform:translateX(-50%);width:178px;padding:10px;text-align:center}.pod-label b{display:block;font-size:14px}.pod-label span{display:block;font-size:12px;color:#c8d1df}.pod-label small{display:inline-block;margin-top:6px;color:var(--green);font-size:10px;letter-spacing:.12em}.agent-detail{position:absolute;left:12px;right:12px;bottom:-36px;text-align:center;font-size:11px;color:#aab6c9;opacity:0;transform:translateY(8px);transition:.25s}.agent-pod:hover .agent-detail,.agent-pod:focus .agent-detail{opacity:1;transform:translateY(0)}.pod-workers i{position:absolute;bottom:18px;width:9px;height:14px;border-radius:8px;background:#9cc9ff;box-shadow:0 0 12px currentColor;animation:agentBob 1.5s ease-in-out infinite}.pod-workers i:nth-child(1){left:40%;animation-delay:-.2s}.pod-workers i:nth-child(2){left:50%;animation-delay:-.7s}.pod-workers i:nth-child(3){left:60%;animation-delay:-1.1s}.moving-agent{position:absolute;z-index:6;left:50%;top:50%;offset-rotate:auto}.moving-agent i{display:block;width:13px;height:21px;border-radius:10px 10px 4px 4px;background:linear-gradient(#e0f2fe,#1e293b);box-shadow:0 0 16px #67e8f9}.route-a{offset-path:path('M 190 160 C 330 250 480 310 610 330');animation:travel 9s linear infinite}.route-b{offset-path:path('M 950 165 C 820 235 740 295 610 330');animation:travel 10s linear infinite -3s}.route-c{offset-path:path('M 235 500 C 365 430 480 390 610 330');animation:travel 11s linear infinite -5s}.route-d{offset-path:path('M 970 505 C 850 430 740 390 610 330');animation:travel 12s linear infinite -7s}.data-cube{position:absolute;width:18px;height:18px;border:1px solid #67e8f9;background:rgba(32,211,255,.18);box-shadow:0 0 24px #22d3ee;transform:rotate(45deg);z-index:5;animation:cubeFloat 3s ease-in-out infinite}.cube-a{left:37%;top:41%}.cube-b{left:65%;top:37%;animation-delay:-1s}.cube-c{left:48%;top:66%;animation-delay:-2s}.bottom-grid{display:grid;grid-template-columns:1fr 1.25fr 1fr 1.8fr;gap:12px}.card{min-height:155px;padding:16px}.card h3{margin:0 0 12px;color:#c084fc;font-size:13px;letter-spacing:.08em}.gauge{width:92px;height:92px;border-radius:50%;display:grid;place-items:center;background:conic-gradient(var(--green) 0 87%,rgba(255,255,255,.1) 87%);box-shadow:0 0 28px rgba(53,242,139,.22)}.gauge b{background:#06101b;border-radius:50%;width:70px;height:70px;display:grid;place-items:center}.network-mini{position:relative;height:70px;background:radial-gradient(circle,rgba(80,120,255,.15),transparent 65%)}.network-mini i{position:absolute;width:16px;height:16px;border-radius:50%;background:#7c3aed;box-shadow:0 0 18px #8b5cf6}.network-mini i:nth-child(1){left:10%;top:45%}.network-mini i:nth-child(2){left:35%;top:12%;background:#22d3ee}.network-mini i:nth-child(3){left:55%;top:52%;background:#f59e0b}.network-mini i:nth-child(4){left:78%;top:22%;background:#35f28b}.network-mini i:nth-child(5){left:66%;top:72%;background:#e879f9}.card ul{list-style:none;margin:0;padding:0}.card li{display:flex;justify-content:space-between;border-bottom:1px solid rgba(255,255,255,.08);padding:8px 0;color:#aeb9ca}.checklist{display:grid;gap:8px}.checklist label{font-size:12px;color:#d3dbea}.right-feed{padding:16px;overflow:hidden}.feed-head{display:flex;justify-content:space-between;margin-bottom:14px}.feed-head span{color:#ff5d4d}.feed-item{display:grid;grid-template-columns:38px 1fr;gap:12px;padding:11px 6px;border-bottom:1px solid rgba(255,255,255,.08);animation:slideIn .55s ease both var(--delay)}.feed-item i{width:34px;height:34px;border-radius:13px;border:1px solid currentColor;box-shadow:0 0 20px currentColor}.feed-item b{display:block;font-size:13px}.feed-item time{float:right;color:#77839b;font-size:11px}.feed-item p{margin:2px 0;color:#c3cede;font-size:12px}.feed-item small{color:#8090a5}.feed-item.violet{color:var(--violet)}.feed-item.sky{color:var(--sky)}.feed-item.emerald{color:var(--emerald)}.feed-item.fuchsia{color:var(--fuchsia)}.feed-item.cyan{color:var(--cyan)}.feed-item.amber{color:var(--amber)}.feed-item.purple{color:#c026d3}.feed-item.orange{color:#fb923c}.full-log,.modal-actions button{border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.04);color:#eaf0ff;border-radius:10px;height:40px;padding:0 14px}.full-log{width:100%;margin-top:14px}.agent-modal{max-width:560px;color:var(--text);padding:24px;border-color:rgba(247,184,75,.45)}.agent-modal::backdrop{background:rgba(0,0,0,.72)}.close-modal{position:absolute;right:12px;top:10px;background:transparent;border:0;color:#fff;font-size:28px}.modal-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:18px}@keyframes spin{to{transform:rotate(360deg)}}@keyframes pulse{50%{transform:scale(1.05);opacity:.55}}@keyframes dash{to{stroke-dashoffset:-80}}@keyframes podBreathe{50%{transform:scale(1.035);filter:brightness(1.2)}}@keyframes agentBob{50%{transform:translateY(-6px);filter:brightness(1.35)}}@keyframes travel{to{offset-distance:100%}}@keyframes cubeFloat{50%{transform:translateY(-14px) rotate(45deg);filter:brightness(1.4)}}@keyframes slideIn{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:none}}@media(max-width:1200px){.habitat-shell{grid-template-columns:84px 1fr}.right-feed{display:none}.sidebar .brand span,.sidebar .brand b,.nav-item:not(.active),.quote{display:none}.sidebar{padding:10px}.topbar{grid-template-columns:1fr}.stats{grid-template-columns:repeat(3,1fr)}.stage{height:620px}.bottom-grid{grid-template-columns:1fr 1fr}}@media(max-width:760px){.habitat-shell{grid-template-columns:1fr;padding:8px}.sidebar{display:none}.stats{grid-template-columns:repeat(2,1fr)}.stage{height:820px}.agent-pod{width:170px}.bottom-grid{grid-template-columns:1fr}}
</style>

<script is:inline>
(() => {
  const root = document.querySelector('[data-agent-habitat]');
  if (!root) return;
  const modal = root.querySelector('[data-agent-modal]');
  const title = root.querySelector('[data-modal-title]');
  const body = root.querySelector('[data-modal-body]');
  const agentCopy = {
    alpha: ['ALPHA PRIME', 'Market analysis agent. Reads market structure, options flow, regime shifts, liquidity, and watchlist behavior before sending summarized research to the Trading Floor.'],
    quantum: ['QUANTUM NODE', 'Signal generation agent. Converts confirmed patterns into scored alerts, never final trades. All outputs route through Risk and CEO B.'],
    sigma: ['SIGMA SCOUT', 'Sentiment scout. Watches news, social chatter, influencer velocity, and crowd mood. Feeds confidence changes to Alpha Prime and Echo Mind.'],
    data: ['DATA WEAVER', 'Pattern recognition engine. Cleans raw inputs, connects bookmarks/research/files, detects repeated setups, and creates checklist-ready findings.'],
    nexus: ['NEXUS CORE', 'Strategy engine. Builds playbooks, tests conditions, compares scenarios, and sends final recommendations to CEO B Command.'],
    omega: ['OMEGA VAULT', 'Risk guardian. Blocks weak ideas, checks position sizing, invalidation, downside, exposure, and duplicate signals.'],
    echo: ['ECHO MIND', 'News and intelligence agent. Converts live headlines and saved research into clean catalyst packets for the Trading Floor.']
  };
  root.querySelectorAll('[data-agent]').forEach(el => {
    el.addEventListener('click', () => {
      const data = agentCopy[el.dataset.agent] || ['Agent', 'Agent details'];
      title.textContent = data[0]; body.textContent = data[1]; modal?.showModal();
    });
  });
  root.querySelector('[data-close-modal]')?.addEventListener('click', () => modal?.close());
})();
</script>
